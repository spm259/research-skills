# Research Skills — API Configuration
# Copy this file to .env and fill in the values you want to use.

# THIS IS AN EXAMPLE FILE - DO NOT PUT REAL KEYS HERE 

# Skills degrade gracefully if keys are absent — see each SKILL.md for fallback behavior.

# ─────────────────────────────────────────────
# Perplexity API
# Used by: source-discovery
# Provides: Deep web synthesis with cited sources via sonar-pro model
# Get key: https://www.perplexity.ai/settings/api
# Free tier: $5 credit on signup
# ─────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ─────────────────────────────────────────────
# Semantic Scholar API (optional — free tier has no key)
# Used by: source-discovery, source-evaluation
# Provides: Cross-discipline academic papers with citation counts
# Without key: 100 req/5min (usually sufficient)
# With key: Higher rate limits
# Get key: https://www.semanticscholar.org/product/api
# ─────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=

# ─────────────────────────────────────────────
# Unpaywall (no key — uses email as identifier)
# Used by: deep-read (to resolve paywalled academic papers)
# Provides: Open-access versions of paywalled papers
# Free — just provide your email address
# ─────────────────────────────────────────────
UNPAYWALL_EMAIL=

# ─────────────────────────────────────────────
# No key needed for:
# - arXiv API (source-discovery) — always free, no auth
# - WebFetch / WebSearch — Claude Code built-ins
# ─────────────────────────────────────────────
